{
    "i18n": true,
    "type": "tabs",
    "items": {
        "panel1": {
            "type": "panel",
            "label": "Settings",
            "items": {
                "_headerColorTheme": {
                    "type": "header",
                    "text": "headerColorTheme",
                    "size": 3
                },
                "colorTheme": {
                    "xs": 12,
                    "sm": 6,
                    "md": 2,
                    "lg": 1,
                    "xl": 1,
                    "type": "select",
                    "label": "colorTheme",
                    "default": 0,
                    "options": [
                        {
                            "label": "default",
                            "value": 0
                        },
                        {
                            "label": "technical",
                            "value": 2
                        },
                        {
                            "label": "tropical",
                            "value": 1
                        },
                        {
                            "label": "sunset",
                            "value": 3
                        },
                        {
                            "label": "volcano",
                            "value": 4
                        }
                    ]
                },
                "_headerweatherEntity": {
                    "type": "header",
                    "text": "headerweatherEntity",
                    "size": 3
                },
                "weatherEntity": {
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 2,
                    "xl": 2,
                    "type": "selectSendTo",
                    "label": "weatherEntityLabel",
                    "default": "",
                    "jsonData": "{ \"internalServerIp\": \"${data.internalServerIp}\" }",
                    "command": "getWeatherEntity"
                },
                "_headerDateFormat": {
                    "type": "header",
                    "text": "headerDateFormat",
                    "size": 3
                },
                "weekdayFormat": {
                    "type": "checkbox",
                    "label": "longWeekdayName",
                    "default": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 3,
                    "lg": 2,
                    "xl": 2
                },
                "monthFormat": {
                    "xs": 12,
                    "sm": 6,
                    "md": 2,
                    "lg": 1,
                    "xl": 1,
                    "type": "select",
                    "label": "MonthFormat",
                    "default": 0,
                    "options": [
                        {
                            "label": "long",
                            "value": 0
                        },
                        {
                            "label": "short",
                            "value": 1
                        },
                        {
                            "label": "numeric",
                            "value": 2
                        }
                    ]
                },
                "yearFormat": {
                    "type": "checkbox",
                    "label": "longYear",
                    "default": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 3,
                    "lg": 2,
                    "xl": 2
                },
                "_headerShutter": {
                    "type": "header",
                    "text": "headerShutter",
                    "size": 3
                },
                "shutterClosedIsZero": {
                    "type": "checkbox",
                    "label": "shutterClosedIsZero",
                    "default": true,
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4
                },
                "_headerCardThermo": {
                    "type": "header",
                    "text": "headerCardThermo",
                    "size": 3
                },
                "defaultValueCardThermo": {
                    "type": "checkbox",
                    "label": "defaultValueCardThermo",
                    "help": "defaultValueCardThermoHint",
                    "default": true,
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4
                },
                "doubleClickTime": {
                    "type": "number",
                    "label": "doubleClickTime",
                    "default": 350,
                    "min": 1,
                    "max": 2000,
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4
                },
                "pw1": {
                    "type": "password",
                    "label": "Service-Pin (numbers only)",
                    "newLine": true,
                    "validator": "data.pw1.search(/[^0-9]+/g) === -1",
                    "validatorNoSaveOnError": true,
                    "validatorErrorText": "mustBeNumber",
                    "xs": 12,
                    "sm": 8,
                    "md": 6,
                    "lg": 4,
                    "xl": 3
                }
            }
        }
    }
}